<Window x:Class="Kinect_WPF_Natif.View.CreateSong.CreateSongWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kinect_WPF_Natif.View.CreateSong"
        mc:Ignorable="d"
        Closed="Window_Closed"
        Title="Création de chanson" Height="900" Width="1600"
            WindowStartupLocation="CenterScreen"
            WindowState="Maximized"
            >

    <Grid Background="#0F0F0F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" 
           Source="/Images/stayfit-logo-long.png" 
           Height="200" 
           Margin="20"
           HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="MovesControl" Margin="20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="128" Height="172" Margin="10" Click="MoveButton_Click" Style="{StaticResource MoveButtonStyle}">
                            <StackPanel>
                                <Image Source="{Binding ImagePath}" Height="128" Stretch="Uniform"/>
                                <TextBlock Text="{Binding DisplayName}" 
                                       Foreground="White" 
                                       HorizontalAlignment="Center" 
                                       FontSize="16" 
                                       Margin="0,10,0,0"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2">
            <Label Name="lblConsole" Content="" Foreground="Red" FontSize="16" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ComboBox Height="24" Margin="0, 0, 32, 0" Width="256"  x:Name="SongSelector" 
                    DisplayMemberPath="Title" 
                    SelectedValuePath="SongId" />
                <Button Name="btnCreer" Content="Créer" Width="96" Height="24" Click="btnCreer_Click"></Button>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>