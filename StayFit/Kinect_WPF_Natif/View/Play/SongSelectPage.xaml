<Page x:Class="Kinect_WPF_Natif.View.Play.SongSelectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kinect_WPF_Natif.View.Play"
      xmlns:conv="clr-namespace:Kinect_WPF_Natif.Model.Converters"
      
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SongSelect">

    <Page.Resources>
        <conv:SongDifficultyToColorConverter x:Key="DiffConverter"/>
        <conv:DifficultyToBarsConverter x:Key="BarsConverter"/>

        <Style x:Key="SongCardStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder" 
                        BorderThickness="4" 
                        Margin="10" 
                        CornerRadius="10" 
                        Background="#1A1A1A"
                        Padding="10"
                        BorderBrush="{Binding Difficulty, Converter={StaticResource DiffConverter}}">
                            <Grid>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="36" FontWeight="Bold"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <ItemsControl ItemsSource="{Binding Difficulty, Converter={StaticResource BarsConverter}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Rectangle Width="50" Height="10" Margin="0,0,8,0" RadiusX="3" RadiusY="3" Fill="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="{Binding Difficulty, StringFormat='({0})'}" Foreground="#888888" FontSize="18" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="White" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Name="btnBack" Content="RETOUR" HorizontalAlignment="Left" Margin="20,20,0,144" 
                Style="{StaticResource MenuButtonStyle}" FontSize="16" Click="btnBackButton_Click"/>

        <Image Grid.Row="0" Source="/Images/stayfit-logo.png" Height="200" Width="600" Margin="20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="SongListBox" 
                     Background="Transparent" 
                     BorderThickness="0"
                     MaxWidth="800"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{StaticResource SongCardStyle}" SelectionChanged="SongListBox_SelectionChanged">
            </ListBox>
        </ScrollViewer>

    </Grid>
</Page>
